# 주차마스터 백엔드 환경 변수 예시
# 실제 운영 시 .env 파일로 복사 후 값 채울 것 (.env는 절대 git에 커밋 금지)

# === 서버 ===
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# === PostgreSQL ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=parkmaster
PG_USER=parkmaster_app
PG_PASSWORD=change_me

# === JWT (운영 시 충분히 긴 무작위 문자열로 변경) ===
JWT_SECRET=change_me_to_a_random_secret_at_least_64_chars_long_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === 쿠키 ===
COOKIE_SECURE=false
COOKIE_DOMAIN=

# === CORS (프론트엔드 도메인. 내부망에서는 같은 호스트라 보통 비워둠) ===
CORS_ORIGIN=http://localhost:5173

# === 파일 업로드 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# === 초기 관리자 계정 (seed:admin 실행 시 사용) ===
ADMIN_EMAIL=admin@parkmaster.local
ADMIN_PASSWORD=changeme1234
ADMIN_NAME=시스템관리자
