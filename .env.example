# ─────────────────────────────────────────────────────────
# WOOJOO ParkMaster — Frontend environment variables
# Copy this file to `.env.local` (git-ignored) and fill in.
# Vite는 VITE_ 접두사 변수만 클라이언트로 노출합니다.
# ─────────────────────────────────────────────────────────

# Supabase (필수)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# 지도 (선택) — KakaoMap 사용 시 입력
# VITE_KAKAO_MAP_KEY=""

# AI 어시스턴트 (선택) — supabase/functions/ai-assistant 활성화 시
# VITE_AI_ENABLED="false"
